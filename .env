# ─── Maestro-Lite Environment ───

# API backend URL (Node.js + SQLite server)
VITE_API_BASE_URL=http://localhost:3000/api

# PTS2 controller URL (fuel pump controller)
VITE_PTS2_URL=http://localhost:8080

# Toggle mock API (true = use in-memory mocks, false = hit real backend)
VITE_USE_MOCK_API=true

# Default station ID (configured per installation)
VITE_STATION_ID=station-001

# App name
VITE_APP_NAME=Maestro-Lite
