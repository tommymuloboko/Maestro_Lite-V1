# ─── Maestro-Lite Environment ───

# API Configuration
# For Cloud (Render):
VITE_API_URL=https://maestro-lite.onrender.com/api
VITE_WS_URL=wss://maestro-lite.onrender.com/ws

# For Local (LAN/Offline) - UNCOMMENT AND ADJUST IP:
# VITE_API_URL=http://localhost:10000/api
# VITE_WS_URL=ws://localhost:10000/ws

# Enable simulated monitoring feed for tanks and pumps screens
VITE_USE_MONITORING_SIMULATOR=true

# Default station ID (configured per installation)
VITE_STATION_ID=station-001

# App name
VITE_APP_NAME=Maestro-Lite
